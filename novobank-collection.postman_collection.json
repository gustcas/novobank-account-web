{
  "info": {
    "name": "NovoBanco Frontend Collection",
    "_postman_id": "4a6b2a5e-6a5d-4dbd-a806-9a10d6d96901",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Happy Path",
          "item": [
            {
              "name": "Registro",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{authBase}}/api/v1/auth/register",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"usuario@novobanco.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Juan Pérez\",\n  \"customerId\": \"{{customerId}}\"\n}"
                }
              }
            },
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const r = pm.response.json();",
                      "pm.environment.set(\"accessToken\", r.accessToken);",
                      "pm.environment.set(\"refreshToken\", r.refreshToken);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{authBase}}/api/v1/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"usuario@novobanco.com\",\n  \"password\": \"Password123!\"\n}"
                }
              }
            },
            {
              "name": "/me",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{authBase}}/api/v1/auth/me"
              }
            },
            {
              "name": "Refresh",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{authBase}}/api/v1/auth/refresh",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                }
              }
            },
            {
              "name": "Logout",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{authBase}}/api/v1/auth/logout"
              }
            }
          ]
        },
        {
          "name": "Error Cases",
          "item": [
            {
              "name": "Login inválido",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{authBase}}/api/v1/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"usuario@novobanco.com\",\n  \"password\": \"passwordincorrecto\"\n}"
                }
              }
            },
            {
              "name": "Token inválido",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer token.invalido.aqui" }],
                "url": "{{authBase}}/api/v1/auth/me"
              }
            },
            {
              "name": "Refresh revocado",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{authBase}}/api/v1/auth/refresh",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"revoked-refresh-token\"\n}"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Account Service",
      "item": [
        {
          "name": "Cuentas",
          "item": [
            {
              "name": "Crear ahorros",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{accountsBase}}/api/v1/accounts",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"type\": \"SAVINGS\",\n  \"currency\": \"USD\"\n}"
                }
              }
            },
            {
              "name": "Crear corriente",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{accountsBase}}/api/v1/accounts",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"type\": \"CHECKING\",\n  \"currency\": \"USD\"\n}"
                }
              }
            },
            {
              "name": "Consultar saldo",
              "request": {
                "method": "GET",
                "url": "{{accountsBase}}/api/v1/accounts/{{accountId}}"
              }
            }
          ]
        },
        {
          "name": "Transacciones",
          "item": [
            {
              "name": "Depósito",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{accountsBase}}/api/v1/transactions/deposits",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 1000.00\n}"
                }
              }
            },
            {
              "name": "Retiro",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{accountsBase}}/api/v1/transactions/withdrawals",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 100.00\n}"
                }
              }
            },
            {
              "name": "Transferencia",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{accountsBase}}/api/v1/transactions/transfers",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"sourceAccountId\": \"{{accountId}}\",\n  \"destinationAccountId\": \"<ACCOUNT_ID_DESTINO>\",\n  \"amount\": 200.00\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Error Cases",
          "item": [
            {
              "name": "Retiro insuficiente (422)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{accountsBase}}/api/v1/transactions/withdrawals",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 999999.00\n}"
                }
              }
            },
            {
              "name": "Cuenta no encontrada (404)",
              "request": {
                "method": "GET",
                "url": "{{accountsBase}}/api/v1/accounts/00000000-0000-0000-0000-000000000000"
              }
            },
            {
              "name": "Malformado (400)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{accountsBase}}/api/v1/transactions/deposits",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"accountId\": \"no-es-un-uuid\",\n  \"amount\": -50\n}"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Flujo Completo E2E",
      "item": [
        {
          "name": "Registro → Login → Crear cuenta → Depositar → Retirar → Transferir",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{authBase}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@novobanco.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Juan Pérez\",\n  \"customerId\": \"{{customerId}}\"\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "authBase", "value": "http://localhost:8081" },
    { "key": "accountsBase", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "accountId", "value": "" },
    { "key": "customerId", "value": "a1b2c3d4-e5f6-7890-abcd-ef1234567890" }
  ]
}
